<?xml version="1.0"?>
<robot name="simple_robot">
  <link name="base_link">
    <visual>
      <geometry>
        <box>
          <size>0.5 0.5 0.5</size> <!-- Simple cube -->
        </box>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <box>
          <size>0.5 0.5 0.5</size>
        </box>
      </geometry>
    </collision>
  </link>
</robot>
