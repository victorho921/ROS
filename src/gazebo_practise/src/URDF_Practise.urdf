<?xml version="1.0"?>
<robot name="robot_trial">
    <!-- Create a list of material -->
    <material name ="something">
        <color rgba ="0.5 0.6 0.8 1"/>
    </material>

    <material name = "green">
        <color rgba ="0 0.6 0 1"/>
    </material>

    <material name = "else">
        <color rgba ="0.8 0.2 0.1 1"/>
    </material>

    <!-- Create the main body -->
    <!-- Create the base footprint - the reference of the ground -->
    <link name ="base_footprint"/>

    <!-- The first link should always be called as base_link -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size= "0.6 0.4 0.2"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="something"/>
        </visual>
    </link>

    <link name= "lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz ="0 0 0" rpy="0 0 0"/>
            <material name="green"/>
        </visual>
    </link>

    <link name ="wheel">
        <visual>
            <geometry>
                <cylinder radius ="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy= "0 0 0"/>
            <material name="else"/>
        </visual>
    </link>

    <joint name="base_lidar_joint" type="fixed">
        <parent link ="base_link"/>
        <child link = "lidar_link"/>
        <!-- This is important to make sure links are properly located -->
        <origin xyz = "0 0 0.125" rpy="0 0 0"/>
    </joint>

    <joint name="base_wheel_joint" type= "continuous">
        <parent link="base_link"/>
        <child link="wheel"/>
        <origin xyz = "-0.15 0 0" rpy="0 0 0"/>
        <!-- Provide the axis of rotation -->
        <axis xyz ="0 0 0.5"/>
    </joint>

    <!-- Create the joint between the ground and the robot -->
    <joint name="base_joint" type="fixed">
        <parent link ="base_footprint"/>
        <child link = "base_link"/>
        <origin xyz = "0 0 0.1" rpy="0 0 0"/>
    </joint>

</robot>


